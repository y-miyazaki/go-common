{
  "servers": {
    "aws-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws==1.4.2",
        "https://aws-mcp.us-east-1.api.aws/mcp"
      ]
    },
    "aws-knowledge-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-proxy==0.12.0",
        "--transport",
        "streamablehttp",
        "https://knowledge-mcp.global.api.aws"
      ]
    },
    "aws-documentation-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.aws-documentation-mcp-server==1.1.24"
      ]
    },
    "aws-pricing-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.aws-pricing-mcp-server==1.0.30"
      ]
    },
    "awslabs-aws-api-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.aws-api-mcp-server==1.3.36"
      ],
      "env": {
        "AWS_REGION": "${env:AWS_REGION}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@2.2.5"
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch==2025.4.7"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-lc",
        "TOKEN=\"$GH_TOKEN\"; if [ -z \"$TOKEN\" ]; then TOKEN=\"$GITHUB_TOKEN\"; fi; uvx mcp-compressor==0.19.8 -- uvx mcp-proxy==0.12.0 --transport streamablehttp -H Authorization \"Bearer $TOKEN\" https://api.githubcopilot.com/mcp/"
      ]
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "codebase-memory-mcp",
      "args": []
    },
    "lean-ctx": {
      "type": "stdio",
      "command": "lean-ctx",
      "args": [
        "mcp"
      ]
    }
  },
  "inputs": []
}