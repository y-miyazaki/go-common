{
  "version": 1,
  "editor": {
    "vimMode": false
  },
  "permissions": {
    "allow": [
      "Shell(actionlint)",
      "Shell(apm)",
      "Shell(ghalint)",
      "Shell(git add)",
      "Shell(git diff)",
      "Shell(git log)",
      "Shell(git status)",
      "Shell(go test)",
      "Shell(golangci-lint)",
      "Shell(markdown-link-check)",
      "Shell(markdownlint-cli2)",
      "Shell(npm run)",
      "Shell(npm test)",
      "Shell(shellcheck)",
      "Shell(shfmt)",
      "Read(**/*.go)",
      "Read(**/*.js)",
      "Read(**/*.json)",
      "Read(**/*.md)",
      "Read(**/*.sh)",
      "Read(**/*.ts)",
      "Read(**/*.yaml)",
      "Read(**/*.yml)",
      "Read(.apm/**)",
      "Read(.claude/**)",
      "Read(.cursor/**)",
      "Read(.devcontainer/**)",
      "Read(.env.example)",
      "Read(.github/**)",
      "Read(.vscode/**)",
      "Read(cmd/**)",
      "Read(docs/**)",
      "Read(lib/**)",
      "Read(pkg/**)",
      "Read(scripts/**)",
      "Read(src/**)",
      "Read(test/**)",
      "Read(tests/**)",
      "Read(Makefile)",
      "Write(**/*.go)",
      "Write(**/*.js)",
      "Write(**/*.md)",
      "Write(**/*.py)",
      "Write(**/*.sh)",
      "Write(**/*.tf)",
      "Write(**/*.tfvars)",
      "Write(**/*.ts)",
      "Write(**/*.yaml)",
      "Write(**/*.yml)",
      "Write(.apm/**)",
      "Write(cmd/**)",
      "Write(docs/**)",
      "Write(lib/**)",
      "Write(pkg/**)",
      "Write(scripts/**)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(tests/**)",
      "Mcp(*:*)"
    ],
    "deny": [
      "Shell(bundle install)",
      "Shell(cargo install)",
      "Shell(composer install)",
      "Shell(curl)",
      "Shell(git branch -D)",
      "Shell(git clean -f)",
      "Shell(git push --force)",
      "Shell(git rebase)",
      "Shell(git reset --hard)",
      "Shell(go get)",
      "Shell(go mod download)",
      "Shell(mix deps.get)",
      "Shell(npm install)",
      "Shell(npm publish)",
      "Shell(pip install)",
      "Shell(pnpm install)",
      "Shell(poetry install)",
      "Shell(rm -rf)",
      "Shell(sudo)",
      "Shell(wget)",
      "Shell(yarn)",
      "Read(**/credentials/**)",
      "Read(**/*.crt)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfstate.*)",
      "Read(**/*.tfbackend)",
      "Read(**/.env.*.local)",
      "Read(**/.env.local)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(env/common/tmp/**)",
      "Read(secrets/**)",
      "Read(temp/**)",
      "Read(tmp/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.azure/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.helm/**)",
      "Read(~/.kube/config)",
      "Read(~/.ssh/id_*)",
      "Read(~/.terraform.d/credentials.tfrc.json)",
      "Write(**/credentials/**)",
      "Write(**/*.crt)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.pem)",
      "Write(**/*.pfx)",
      "Write(**/*.tfstate)",
      "Write(**/*.tfstate.*)",
      "Write(**/*.tfbackend)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(secrets/**)",
      "Write(~/**)"
    ]
  }
}
