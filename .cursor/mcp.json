{
  "mcpServers": {
    "aws-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws==1.4.2",
        "https://aws-mcp.us-east-1.api.aws/mcp"
      ]
    },
    "aws-knowledge-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-proxy==0.12.0",
        "--transport",
        "streamablehttp",
        "https://knowledge-mcp.global.api.aws"
      ]
    },
    "aws-documentation-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.aws-documentation-mcp-server==1.1.24"
      ]
    },
    "aws-pricing-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "awslabs.aws-pricing-mcp-server==1.0.30"
      ]
    },
    "awslabs-aws-api-mcp-server": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "AWS_REGION": "${AWS_REGION}"
      },
      "args": [
        "awslabs.aws-api-mcp-server==1.3.36"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@2.2.5"
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch==2025.4.7"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-lc",
        "TOKEN=\"${GH_TOKEN:-$GITHUB_TOKEN}\"; exec uvx mcp-compressor==0.31.5 -- https://api.githubcopilot.com/mcp/ -H \"Authorization=Bearer ${TOKEN}\" --auth explicit-headers"
      ]
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "codebase-memory-mcp",
      "args": []
    },
    "lean-ctx": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "lean-ctx-bin"
      ]
    }
  }
}